# MTCv1 — Environment Variables
# Copy this to .env.local and fill in your Supabase credentials

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (for pg_dump backups — find in: Supabase Dashboard → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Site URL (used for auth redirects — set to your production domain)
NEXT_PUBLIC_SITE_URL=https://www.monotennisclub.com

# SMTP (booking confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# VAPID keys (push notifications — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:your-email@gmail.com

# Mobile PWA demo auth passwords (optional — defaults to simple demo passwords)
# Override these in production to prevent unauthorized demo access
# DEMO_MEMBER_PW=
# DEMO_COACH_PW=
# DEMO_ADMIN_PW=
